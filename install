# git project name
PROJECT_BASE=base-compose
PROJECT_CONFIGURATION_EXPORTER=configuration-exporter-compose
PROJECT_CONFIGURATION_MANAGER=configuration-manager-compose
PROJECT_PERFORMANCE_COLLECTOR=performance-collector-compose
PROJECT_PERFORMANCE_EXPORTER=performance-exporter-compose
PROJECT_PERFORMANCE_MANAGER=performance-manager-compose
PROJECT_MF_CORE=mf-core
PROJECT_MF_ALERT=mf-alert
PROJECT_LAYOUT_APPLY=layout-apply-compose
PROJECT_MIGRATION_PROCEDURE_GENERATOR=migration-procedure-generator-compose
PROJECT_HW_CONTROL=hw-control-compose
PROJECT_ALERT_MANAGER=alert-manager-compose
PROJECT_JOB_MANAGER=job-manager-compose
PROJECT_LAYOUT_DESIGN=layout-design-compose
PROJECT_POLICY_MANAGER=policy-manager-compose

# COMPOSE_ARRAY variable is an array that stores the paths of multiple Docker Compose files.
# It assumes that the Docker Compose files are located in the same directory.
# If there are multiple Docker Compose files, specify the override files separated by a colon.
COMPOSE_ARRAY=(
	"$PROJECT_BASE"
	"$PROJECT_CONFIGURATION_EXPORTER"
	"$PROJECT_CONFIGURATION_MANAGER"
	"$PROJECT_PERFORMANCE_COLLECTOR"
	"$PROJECT_PERFORMANCE_EXPORTER"
	"$PROJECT_PERFORMANCE_MANAGER"
	"$PROJECT_LAYOUT_APPLY"
	"$PROJECT_MIGRATION_PROCEDURE_GENERATOR"
	"$PROJECT_HW_CONTROL"
	"$PROJECT_MF_CORE"
	"$PROJECT_MF_ALERT"
	"$PROJECT_ALERT_MANAGER"
	"$PROJECT_JOB_MANAGER"
	"$PROJECT_LAYOUT_DESIGN"
	"$PROJECT_POLICY_MANAGER"
)

# args build flag
flg_build=""
# args up flag
flg_up=""

# docker network name
NETWORK_NAME=cdim-net

# ----------------------------
# args
# ----------------------------
function usage() {
cat <<EOF
usage: install [option]
The installer builds and launches CDIM.
This command, by default, displays this usage.

  option:
  -b, --build  Build.
  -u, --up     Start.
  -h, --help   Show and exit this usage.
EOF
}

# Show usage if no arguments provided
if [ $# -eq 0 ]; then
    usage
    exit 0
fi

while [ -n "${1:-}" ]; do
	case "$1" in
		-h|--help) usage; exit 0;;
		-b|--build) flg_build='on';;
		-u|--up) flg_up='on';;
		-*) echo -e 'cdim: error: Invalid option. Use "--help".'; exit 1;;
	esac
	shift
done


# ----------------------------
# create docker network
# ----------------------------
if [ "$(docker network ls | grep -c "$NETWORK_NAME")" -lt 1 ]; then
	if ! docker network create "$NETWORK_NAME"; then
		exit 2
	fi
	echo "cdim: docker network created. [$NETWORK_NAME]"
fi


# ----------------------------
# docker build and up
# ----------------------------
SCRIPT_DIR="$(cd "$(dirname "$0")" || exit; pwd)"
cd "$SCRIPT_DIR" || exit

for compose_dir in "${COMPOSE_ARRAY[@]}"; do
	cd "$compose_dir" || exit

	# Special handling for mf-core which uses compose.prod.yaml
	if [ "${compose_dir}" = "${PROJECT_MF_CORE}" ]; then
		COMPOSE_FILE="compose.prod.yaml"
		export COMPOSE_FILE
	else
		# Use default compose files (compose.yml and compose.override.yml if exists)
		unset COMPOSE_FILE
	fi

	# build ----- -----
	if [ "$flg_build" == "on" ]; then
		if ! docker compose build; then
			exit 3
		fi
		echo "cdim: docker compose build done. [$compose_dir]"
	fi

	# up ----- -----
	if [ "$flg_up" == "on" ]; then
		if ! docker compose up -d; then
			exit 4
		fi
	fi
	cd "$SCRIPT_DIR" || exit
done

exit 0
